# Streamlit secrets template.
#
# LOCAL DEV:  copy this file to  .streamlit/secrets.toml  and fill it in.
#             (.streamlit/secrets.toml is gitignored — never commit it.)
# CLOUD:      paste the contents (without this comment block) into your app on
#             Streamlit Community Cloud → Settings → Secrets. That store is
#             durable across restarts, unlike the Cloud filesystem.

# ----- Optional password gate (defense-in-depth) ---------------------------- #
# If set, the whole app is gated behind this password. Remove/leave blank to
# disable. This is a light gate; keep the GitHub repo PRIVATE as the real guard.
app_password = "change-me"

# ----- API keys (none required today) --------------------------------------- #
# yfinance needs no key. If you add a provider that does, put the key here and
# read it via st.secrets["..."] — never hardcode keys in app.py.
# stooq_api_key = "..."

# ----- Holdings (durable store for Streamlit Cloud) ------------------------- #
# On Cloud the filesystem is ephemeral, so holdings.csv edits do not persist.
# Define holdings here instead. The app loads these in preference to any CSV.
# Generate this block from the in-app Edit tab → "Copy as secrets TOML".

[[holdings]]
ticker = "VOO"
quantity = 10
asset_class = "equity"
cost_basis = 420.50
account = "IBKR"
note = "S&P 500 ETF (USD)"

[[holdings]]
ticker = "ESLT.TA"
quantity = 5
asset_class = "equity"
account = "Bank Hapoalim"
note = "Elbit Systems (TASE/ILS)"
